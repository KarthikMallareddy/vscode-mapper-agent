{
  "name": "vscode-mapper-agent",
  "displayName": "@mapper",
  "description": "AI-powered architecture mapping for VS Code using LangChain.",
  "version": "0.0.1",
  "publisher": "harry-brave",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Visualization"
  ],
  "activationEvents": [
    "onChatParticipant:mapper"
  ],
  "main": "./dist/extension.js",
  "enabledApiProposals": [
    "chatParticipant"
  ],
  "contributes": {
    "chatParticipants": [
      {
        "id": "mapper",
        "name": "mapper",
        "description": "I can visualize your project architecture. Ask me to /draw a map!"
      }
    ],
    "commands": [
      {
        "command": "mapper.setGeminiKey",
        "title": "Mapper: Set Gemini API Key"
      }
    ],
    "configuration": {
      "title": "@mapper",
      "properties": {
        "mapper.useUserKey": {
          "type": "boolean",
          "default": true,
          "description": "Whether to use your own Gemini API key for mapping."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@langchain/google-genai": "^2.1.20"
  }
}